{
  "name": "Homework ordering System",
  "description": "Base Level Extension",
  "version": "1.0",
  "manifest_version": 3,
  
  "action": {

    "default_icon": {
      "16": "images/enabled-16.png",
      "32": "images/enabled-32.png",
      "48": "images/enabled-48.png",
      "128": "images/enabled-128.png"
    },
    "default_popup": "index.html"
  },
  "content_security_policy": {
    "extension_pages": 
        "script-src 'self'; object-src 'self'"
    },
    

  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "permissions": ["activeTab", "scripting", "storage"],
  "host_permissions": [
  "https://learning.stmichaels.vic.edu.au/*"
  ],
  "commands": {
    "_execute_action": {
      "suggested_key": {
        "default": "Ctrl+B",
        "mac": "Command+B"
      }
    }
  },
  
  "content_scripts": [
    {
      "matches": ["https://learning.stmichaels.vic.edu.au/calendar/week*"],
      "js": ["classes.js","sorting.js","hoursSect.js","weighting.js","taskPopup.js","content.js"]
    }
  ]

}
  
